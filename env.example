# Copy to .env and adjust. Required for `npm run dev` (API server).

# Required — use a long random string in production (min 16 characters).
JWT_SECRET=dev-only-change-me-please-use-long-secret

# SPA origin (CORS + OAuth redirect after Google sign-in).
FRONTEND_ORIGIN=http://localhost:5173

# OAuth redirect_uri must match Google Cloud console. With Vite dev proxy, use the SPA origin.
API_PUBLIC_URL=http://localhost:5173

PORT=3001

# When set, users + repertoires + PGN lines use PostgreSQL (e.g. Docker: postgresql://user:pass@host:5432/db).
# When unset, the API uses SQLite (default: server/data/app.db).
# DATABASE_URL=postgresql://chessrat:chessrat@localhost:5432/chessrat

# Optional — default is server/data/app.db (SQLite only)
# DATABASE_PATH=

# Production / Docker over HTTP: allow session cookies without Secure (set to 1 behind plain HTTP).
# TRUST_HTTP_COOKIES=1

# Serve Vite build from the API (Docker image sets SERVE_STATIC=1).
# SERVE_STATIC=1

# Google OAuth2 (optional — leave empty to hide Google buttons)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# In-app admin dashboard (/admin/analytics): comma-separated emails (lowercase).
# ADMIN_EMAILS=you@example.com

# SPA: optional GA4 measurement ID (e.g. G-XXXXXXXXXX) for page views.
# VITE_GA_MEASUREMENT_ID=

# Optional — transactional email (confirmation + password reset)
# APP_NAME=Chess Loop
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=0
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM="Chess Loop <noreply@example.com>"
